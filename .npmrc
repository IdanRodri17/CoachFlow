# Expo SDK 56 ships React 19, whose ecosystem peer ranges still lag slightly
# (e.g. a transitive react-dom@19.2.7 demanding react@^19.2.7 while Expo pins
# react@19.2.3). These are version-range mismatches, not real incompatibilities.
# `legacy-peer-deps` tells npm to install anyway using the React version Expo
# chose. EAS cloud builds and local `npm install` both honor this file, so the
# dependency tree resolves the same everywhere. Revisit once the RN 19 ecosystem
# tightens its peer ranges.
legacy-peer-deps=true
