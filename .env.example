# CoachFlow environment variables — TEMPLATE.
#
# Copy this file to ".env" and fill in real values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# The "EXPO_PUBLIC_" prefix is required: only variables with that prefix are
# exposed to the app at runtime via process.env. The anon key is SAFE to ship in
# a client app — it only grants the access your Row-Level Security policies allow.
# NEVER put the Supabase "service_role" key in here or anywhere in the app.
#
# The real ".env" is gitignored — do not commit it.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
